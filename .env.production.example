# =============================================================================
# PlacePOS PWA - Variables de entorno para DESPLIEGUE en la VM.
#
# Copia a `.env` en la VM y ajusta. NO comitear el `.env` real.
# Lo usa `docker-compose.prod.yml` (vía deploy.sh).
#
# OJO: la URL del backend (PUBLIC_API_URL) NO va aquí. El SPA es estático y la
# hornea en BUILD-TIME el workflow de CI (repo Variable PUBLIC_API_URL). Cambiar
# la URL del API requiere reconstruir la imagen, no editar este .env.
# =============================================================================

# Imagen Docker a desplegar (la publica el workflow en GHCR). Lower-case.
IMAGE_NAME=ghcr.io/CHANGEME/placepos_pwa_app:latest

# Dominio público de la PWA (sin protocolo). Apunta el A-record a la IP de la VM
# ANTES de correr ./deploy.sh la primera vez.
DOMAIN=erp.kikedevs.com

# Email para Let's Encrypt (avisos de expiración / renovación).
LETSENCRYPT_EMAIL=kikedevelopers@gmail.com

# 1 = servidor de pruebas de Let's Encrypt (cert no confiable, sin rate limit
# duro). Útil para validar el setup la primera vez. 0 para producción.
LETSENCRYPT_STAGING=0
